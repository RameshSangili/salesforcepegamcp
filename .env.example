# Copy this to .env for local testing — never commit .env to git

# Required: Salesforce PegaIntegration Connected App consumer secret
SALESFORCE_CLIENT_SECRET=

# Required: refresh token obtained once via Authorization Code flow (see README)
SALESFORCE_REFRESH_TOKEN=

# Optional: shared secret Pega sends as Bearer token so only Pega can call this proxy.
# Leave blank to disable the check (not recommended in production).
PEGA_EXPECTED_TOKEN=

# Optional: override the default Salesforce MCP endpoint
# SALESFORCE_MCP_URL=https://api.salesforce.com/platform/mcp/v1/platform/sobject-all
